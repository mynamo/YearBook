# Rename to .streamlit/secrets.toml (local) or paste into the Secrets box on
# Streamlit Community Cloud. Never commit real credentials to GitHub.

[spotify]
client_id = "your_spotify_client_id"
client_secret = "your_spotify_client_secret"
# Must EXACTLY match a Redirect URI registered in your Spotify app dashboard.
# Local dev:  http://127.0.0.1:8501   (Spotify no longer allows http://localhost)
# Deployed:   https://your-app-name.streamlit.app
redirect_uri = "http://127.0.0.1:8501"

[reddit]
# Create a "web app" at https://www.reddit.com/prefs/apps
client_id = "your_reddit_client_id"
client_secret = "your_reddit_client_secret"
# Must EXACTLY match the redirect URI set on your Reddit app.
# Local dev:  http://localhost:8501     Deployed: https://your-app-name.streamlit.app
redirect_uri = "http://localhost:8501"
user_agent = "yearbook-wrapped/1.0 by u/yourname"
